@Library('Shared') _
pipeline {
    agent { label 'docker-agent' }

    parameters {
        string(name: 'FRONTEND_DOCKER_TAG', defaultValue: '', description: 'Frontend Docker tag passed from CI job')
        string(name: 'BACKEND_DOCKER_TAG', defaultValue: '', description: 'Backend Docker tag passed from CI job')
    }

    stages {
        stage("Validate Parameters") {
            steps {
                script {
                    if (!params.FRONTEND_DOCKER_TAG?.trim() || !params.BACKEND_DOCKER_TAG?.trim()) {
                        error("Both FRONTEND_DOCKER_TAG and BACKEND_DOCKER_TAG must be provided.")
                    }
                    echo "FRONTEND_DOCKER_TAG: ${params.FRONTEND_DOCKER_TAG}"
                    echo "BACKEND_DOCKER_TAG: ${params.BACKEND_DOCKER_TAG}"
                }
            }
        }

        stage("Workspace Cleanup") {
            steps {
                cleanWs()
            }
        }

        stage('Git: Code Checkout') {
            steps {
                script {
                    clone("https://github.com/sachitrrazdan1710/Wanderlust-Mega-Project.git", "devops")
                }
            }
        }

        stage("Update Kubernetes Manifests") {
            steps {
                script {
                    dir('kubernetes') {
                        sh """
                        sed -i 's|image: .*wanderlust-backend:.*|image: sachitrrazdan1710/wanderlust-backend:${params.BACKEND_DOCKER_TAG}|' backend.yaml
                        sed -i 's|image: .*wanderlust-frontend:.*|image: sachitrrazdan1710/wanderlust-frontend:${params.FRONTEND_DOCKER_TAG}|' frontend.yaml

                        echo "Updated backend.yaml:"
                        grep 'image:' backend.yaml || true

                        echo "Updated frontend.yaml:"
                        grep 'image:' frontend.yaml || true
                        """
                    }
                }
            }
        }

        stage("Git: Commit and Push Manifest Changes") {
            steps {
                script {
                    withCredentials([gitUsernamePassword(credentialsId: 'Github-cred', gitToolName: 'Default')]) {
                        sh """
                        git config user.name "Jenkins"
                        git config user.email "jenkins@local"

                        git status
                        git add kubernetes/backend.yaml kubernetes/frontend.yaml
                        git commit -m "Update Kubernetes manifests: backend=${params.BACKEND_DOCKER_TAG}, frontend=${params.FRONTEND_DOCKER_TAG}" || echo "No changes to commit"
                        git push origin devops
                        """
                    }
                }
            }
        }
    }

    post {
        success {
            script {
                emailext attachLog: true,
                subject: "Wanderlust Deployment SUCCESS - ${env.JOB_NAME}",
                body: """
                    <html>
                    <body>
                        <h2 style="color:green;">Deployment Successful 🚀</h2>
                        <p><b>Project:</b> ${env.JOB_NAME}</p>
                        <p><b>Build:</b> ${env.BUILD_NUMBER}</p>
                        <p><b>Frontend Tag:</b> ${params.FRONTEND_DOCKER_TAG}</p>
                        <p><b>Backend Tag:</b> ${params.BACKEND_DOCKER_TAG}</p>
                        <p><b>URL:</b> ${env.BUILD_URL}</p>
                    </body>
                    </html>
                """,
                to: 'sachitrrazdan399@gmail.com',
                mimeType: 'text/html'
            }
        }

        failure {
            script {
                emailext attachLog: true,
                subject: "Wanderlust Deployment FAILED - ${env.JOB_NAME}",
                body: """
                    <html>
                    <body>
                        <h2 style="color:red;">Deployment Failed ❌</h2>
                        <p><b>Project:</b> ${env.JOB_NAME}</p>
                        <p><b>Build:</b> ${env.BUILD_NUMBER}</p>
                        <p><b>Frontend Tag:</b> ${params.FRONTEND_DOCKER_TAG}</p>
                        <p><b>Backend Tag:</b> ${params.BACKEND_DOCKER_TAG}</p>
                    </body>
                    </html>
                """,
                to: 'sachitrrazdan399@gmail.com',
                mimeType: 'text/html'
            }
        }
    }
}
